{
  "name": "cryo-wiring-viewer",
  "displayName": "Cryo-Wiring Viewer",
  "description": "Preview cooldown.yaml files as interactive wiring diagrams",
  "version": "0.1.0",
  "publisher": "cryo-wiring",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cryo-wiring/vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "icons/icon128.png",
  "contributes": {
    "commands": [
      {
        "command": "cryo-wiring.previewCooldown",
        "title": "Preview Cooldown",
        "category": "Cryo-Wiring",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /cooldown\\.ya?ml$/",
          "command": "cryo-wiring.previewCooldown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "~5.6.0"
  }
}
